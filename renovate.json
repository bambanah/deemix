{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended",
		":semanticCommits",
		"security:only-security-updates",
		"security:openssf-scorecard"
	],
	"packageRules": [
		{
			"matchFileNames": [".github/workflows/build-publish-docker.yml"],
			"matchPackageNames": ["*"],
			"semanticCommitScope": "webui",
			"enabled": true
		},
		{
			"matchFileNames": [".github/workflows/build-publish-cli.yml"],
			"matchPackageNames": ["*"],
			"semanticCommitScope": "cli",
			"enabled": true
		},
		{
			"matchFileNames": [".github/workflows/build-publish-electron.yml"],
			"matchPackageNames": ["*"],
			"semanticCommitScope": "gui",
			"enabled": true
		},
		{
			"matchFileNames": [
				".github/workflows/create-release-or-publish.yml",
				".github/workflows/pull-request.yml"
			],
			"matchPackageNames": ["*"],
			"semanticCommitScope": "ci",
			"enabled": true
		},
		{
			"matchFileNames": ["*"],
			"matchManagers": ["docker"],
			"enabled": true
		}
	],
	"osvVulnerabilityAlerts": true,
	"vulnerabilityAlerts": {
		"enabled": true,
		"labels": ["security"]
	}
}
